{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "README Integrity Rules",
  "type": "object",
  "properties": {
    "required_sections": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "const": "Estado actual" }
    },
    "require_verifiable_paths": {
      "type": "boolean",
      "const": true
    },
    "allow_legacy_narrative": {
      "type": "boolean",
      "const": false
    }
  },
  "required": ["required_sections", "require_verifiable_paths", "allow_legacy_narrative"]
}
