
# DUMMIE Engine - Environment Configuration Template
# Copy this file to .env and adjust values for your local setup.

# Core paths (use absolute paths for your machine)
DUMMIE_ROOT_DIR="/path/to/DUMMIE Engine"
DUMMIE_AIWG_DIR="/path/to/DUMMIE Engine/.aiwg"
MEMORY_SOCKET_PATH="/path/to/DUMMIE Engine/.aiwg/sockets/flight.sock"
DUMMIE_KUZU_DB_PATH="/path/to/DUMMIE Engine/.aiwg/memory/loci.db"

# Local Reasoning (Ollama/Gemma)
DUMMIE_LOCAL_REASONING_PROVIDER="ollama"
DUMMIE_OLLAMA_BASE_URL="http://127.0.0.1:11434"
DUMMIE_GEMMA_MODEL="gemma4"
