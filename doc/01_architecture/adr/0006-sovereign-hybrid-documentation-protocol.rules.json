{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hybrid Execution & Documentation Constraints",
  "type": "object",
  "properties": {
    "polyglot_build_environment": {
      "type": "string",
      "enum": ["docker", "nix"],
      "description": "L0, L1, L3, L4, L5 must be built using Docker if Nix is unavailable."
    },
    "documentation_integrity": {
      "type": "object",
      "properties": {
        "allow_premature_finalization": { "type": "boolean", "const": false },
        "require_real_time_updates": { "type": "boolean", "const": true }
      }
    }
  },
  "required": ["polyglot_build_environment", "documentation_integrity"]
}
