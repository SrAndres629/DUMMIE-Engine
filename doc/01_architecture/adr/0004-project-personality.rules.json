{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project Personality Constraints",
  "type": "object",
  "properties": {
    "identity_file_path": {
      "type": "string",
      "const": ".aiwg/identity.json"
    },
    "forbidden_phrases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": ["Como modelo de lenguaje", "As an AI"]
    }
  },
  "required": ["identity_file_path"]
}
