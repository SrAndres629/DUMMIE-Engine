{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Zero-Sudo Enforcement Rules",
  "type": "object",
  "properties": {
    "allow_sudo": {
      "type": "boolean",
      "const": false,
      "description": "Terminantemente prohibido el uso de sudo en scripts automáticos."
    },
    "preferred_tool_paths": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["$HOME/.local/bin", "$HOME/go/bin", "./bin"]
    }
  },
  "required": ["allow_sudo"]
}
