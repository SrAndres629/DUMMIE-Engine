{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Metacognitive Audit Rules",
  "type": "object",
  "properties": {
    "audit_triggers": {
      "type": "array",
      "items": { "type": "string", "enum": ["LAYER_SYNC_COMPLETE", "JIDOKA_THRESHOLD_REACHED"] }
    },
    "trait_mutation_limits": {
      "type": "object",
      "properties": {
        "max_delta_per_cycle": { "type": "number", "maximum": 0.2 },
        "min_refactoring_aggressiveness": { "type": "number", "minimum": 0.1 }
      }
    }
  },
  "required": ["audit_triggers", "trait_mutation_limits"]
}
