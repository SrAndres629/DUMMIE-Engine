{
  "rule_id": "RULE_AO_V2_L3_47",
  "spec_ref": "DE-V2-L3-47",
  "invariants": {
    "forbidden_patterns": [
      "REAL_KEY_IN_CONTEXT",
      "UNMASKED_LOGGING",
      "CROSS_SCOPE_SECRET_DISCOVERY"
    ],
    "required_headers": [
      "X-AO-Vault-ID",
      "X-AO-Placeholder-ID"
    ],
    "vault_architecture": {
      "storage": "L3_Encrypted_Enclave",
      "injection_method": "Placeholder_Hydration"
    },
    "secret_lifecycle": {
      "request": "Placeholder ($VAULT_*)",
      "hydration": "L1/L5_Adapter_Outbound"
    }
  },
  "enforcement": "STRICT_BLOCK",
  "scrubbing_policy": {
    "auto_redact": true,
    "shannon_entropy_threshold": 4.5
  }
}
