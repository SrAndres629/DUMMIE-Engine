# --- DUMMIE Engine .gitignore ---

# Logs & Temporales
*.log
*.old
tmp/
# Memoria local dinámica AIWG
.aiwg/index/
.aiwg/events/
.aiwg/sessions/
.aiwg/cache/
.aiwg/runtime/
.aiwg/memory/
.aiwg/ledger/
.aiwg/security_state
.aiwg/venv_ssh/
.aiwg/*.jsonl
.aiwg/*.db
.aiwg/obsidian_vault/**/.obsidian/plugins/*/data.json

!.aiwg/
!.aiwg/README.md
!.aiwg/control/
!.aiwg/control/**
!.aiwg/templates/
!.aiwg/templates/**
!.aiwg/self_model/
!.aiwg/self_model/**
.gemini/
.worktrees/
.env

# Binarios y Artefactos de Build
bin/
_build/
deps/
*.beam
*.ez
target/
zig-out/
zig-cache/

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.uv/

# Node.js
node_modules/
dist/

# Protobuf (Solo ignoramos los generados si queremos mantener la 'Physical Truth' en el repo)
# Por política SDD, preferimos mantener los stubs si son necesarios para el despliegue,
# pero en este caso los ignoraremos para forzar el build local.
# layers/l0_overseer/lib/proto/
# layers/l1_nervous/proto/
# layers/l2_brain/proto/

# OS
.DS_Store
.idea/
.vscode/
Obsidian.AppImage
squashfs-root/
venv/
scratch/venv/
*.so
*.dll
*.dylib
