{
  "mcpServers": {
    "dummie-brain-adapter": {
      "command": "./layers/l2_brain/.venv/bin/python",
      "args": [
        "./layers/l1_nervous/mcp_server.py"
      ],
      "env": {
        "DUMMIE_ROOT_DIR": ".",
        "DUMMIE_AIWG_DIR": "./.aiwg",
        "DUMMIE_KUZU_DB_PATH": "./.aiwg/memory/loci.db",
        "PYTHONPATH": "./layers/l2_brain:./layers/l1_nervous",
        "DUMMIE_MCP_CONFIG_PATH": "./dummie_agent_config.json"
      }
    },
    "local-ssh-context": {
      "command": "/bin/bash",
      "args": [
        "./layers/l1_nervous/ssh_sandbox_wrapper.sh"
      ]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "git": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git", "--repository", "/home/jorand/Escritorio/DUMMIE Engine"]
    }
  }
}
