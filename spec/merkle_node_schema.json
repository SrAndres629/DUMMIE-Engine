{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MerklePosetNode",
  "description": "Esquema para un nodo de memoria 4D-TES con integridad causal Merkle.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Identificador único del nodo."
    },
    "content": {
      "type": "object",
      "description": "Contenido semántico y datos del nodo."
    },
    "parent_hashes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Lista ordenada de hashes de los nodos padres."
    },
    "causal_hash": {
      "type": "string",
      "description": "Hash criptográfico (SHA-256) de Canonical_JSON(content) + Hex(Sort(parent_hashes))."
    }
  },
  "required": ["id", "content", "parent_hashes", "causal_hash"],
  "additionalProperties": false
}
