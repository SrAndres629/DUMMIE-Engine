{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Swarm Governance Constraints",
  "type": "object",
  "properties": {
    "defined_departments": {
      "type": "array",
      "items": { "type": "string", "enum": ["Strategy", "Architecture", "Engineering", "QA"] }
    },
    "jidoka_authority": {
      "type": "boolean",
      "const": true,
      "description": "Todos los agentes deben tener la capacidad de detener la línea."
    }
  },
  "required": ["defined_departments", "jidoka_authority"]
}
