{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Swarm Governance Constraints [2026]",
  "type": "object",
  "properties": {
    "defined_departments": {
      "type": "array",
      "items": { "type": "string", "enum": ["ContractDesign", "BehaviorSynth", "Implementation", "ValidationMemory"] }
    },
    "jidoka_authority": {
      "type": "boolean",
      "const": true,
      "description": "Todos los agentes deben tener la capacidad de detener la línea (Jidoka) si se detecta una desviación del contrato."
    }
  },
  "required": ["defined_departments", "jidoka_authority"]
}
