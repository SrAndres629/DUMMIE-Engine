{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Collaboration Rules",
  "type": "object",
  "properties": {
    "required_handoff_fields": {
      "type": "array",
      "items": { "type": "string", "enum": ["changed_files", "assumptions", "validation_evidence", "open_risks"] }
    },
    "deterministic_conflict_resolution": {
      "type": "boolean",
      "const": true
    },
    "allow_unverified_completion_claims": {
      "type": "boolean",
      "const": false
    }
  },
  "required": ["required_handoff_fields", "deterministic_conflict_resolution", "allow_unverified_completion_claims"]
}
